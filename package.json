{
  "name": "@kwo1/berus",
  "version": "0.0.3",
  "description": "A lightweight CLI framework for TypeScript heavily inspired by Go's Cobra",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "compile": "tsc -p tsconfig.build.json",
    "build": "run-s lint test clean compile",
    "lint": "run-s lint:format lint:code",
    "lint:format": "prettier -c ./src ./tests ./example ./package.json ./package-lock.json ./tsconfig.json ./tsconfig.build.json ./eslint.config.js",
    "lint:format:fix": "prettier -w ./src ./tests ./example ./package.json ./package-lock.json ./tsconfig.json ./tsconfig.build.json ./eslint.config.js",
    "lint:code": "run-s lint:eslint lint:types",
    "lint:code:fix": "eslint . --fix",
    "lint:eslint": "eslint .",
    "lint:types": "tsc -p tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts",
    "example": "tsx example/main.ts",
    "example:kitchen": "tsx example/kitchen-sink.ts",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "berus",
    "cli",
    "typescript"
  ],
  "author": "Karl Ostendorf <karl@ostendorf.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwo/berus.git"
  },
  "bugs": {
    "url": "https://github.com/kwo/berus/issues"
  },
  "homepage": "https://github.com/kwo/berus#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.15.21",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "eslint": "10.2.1",
    "husky": "9.1.7",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2"
  }
}
