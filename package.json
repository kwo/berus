{
  "name": "@kwo1/berus",
  "version": "0.0.9",
  "description": "A lightweight CLI framework for TypeScript heavily inspired by Go's Cobra",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "dev": "tsx example/main.ts",
    "compile": "tsc -p tsconfig.json --noEmit false --declaration --rootDir ./src --outDir ./dist",
    "build": "run-s clean compile",
    "format": "prettier -c ./src ./tests ./example ./package.json ./tsconfig.json ./eslint.config.js",
    "format:fix": "prettier -w ./src ./tests ./example ./package.json ./tsconfig.json ./eslint.config.js",
    "code": "run-s code:eslint code:types",
    "code:fix": "run-s code:eslint:fix",
    "code:eslint": "eslint .",
    "code:eslint:fix": "eslint . --fix",
    "code:types": "tsc -p tsconfig.json",
    "lint": "run-s format code",
    "lint:fix": "run-s format:fix code:fix",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "run-s lint test",
    "example": "tsx example/main.ts",
    "example:kitchen": "tsx example/kitchen-sink.ts",
    "prepare": "husky",
    "prepublishOnly": "run-s check build"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "berus",
    "cli",
    "typescript"
  ],
  "author": "Karl Ostendorf <karl@ostendorf.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwo/berus.git"
  },
  "bugs": {
    "url": "https://github.com/kwo/berus/issues"
  },
  "homepage": "https://github.com/kwo/berus#readme",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.15.21",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "eslint": "10.2.1",
    "husky": "9.1.7",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2"
  }
}
